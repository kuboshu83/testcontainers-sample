<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.test_sample.infrastructure.user.UserDao">
    <insert id="save">
        insert into users (id, name, email)
        values (#{user.id}, #{user.name}, #{user.email})
    </insert>

    <delete id="deleteById">
        delete from users where id = #{id}
    </delete>

    <select id="findById" resultType="com.example.test_sample.infrastructure.user.UserRecord">
        select id, name, email from users where id = #{id}
    </select>

    <select id="findAll" resultType="com.example.test_sample.infrastructure.user.UserRecord">
        select id, name, email from users
    </select>
</mapper>