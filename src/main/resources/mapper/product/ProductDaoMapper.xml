<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.test_sample.infrastructure.product.ProductDao">
    <insert id="save">
        insert into product (id, name, price)
        values (#{product.id}, #{product.name}, #{product.price})
    </insert>

    <delete id="deleteById">
        delete from product where id = #{id}
    </delete>

    <select id="findById" resultType="com.example.test_sample.infrastructure.product.ProductRecord">
        select id, name, price from product where id = #{id}
    </select>

    <select id="findAll" resultType="com.example.test_sample.infrastructure.product.ProductRecord">
        select id, name, email from product
    </select>
</mapper>